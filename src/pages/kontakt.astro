---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { company } from "@data/site";
---

<BaseLayout
  title="Kontakt | Schreck Kunststofftechnik – Formenbau Burgwald-Bottendorf"
  description="Kontakt zu Schreck Kunststofftechnik GmbH in Burgwald-Bottendorf: Telefon, E-Mail, Adresse und Projektanfrage."
>
  <PageHero eyebrow="Kontakt" title="Projekt anfragen" text="Senden Sie Zeichnungen, Muster oder Anforderungen. Schreck prüft Ihr Vorhaben und meldet sich mit einer fachlichen Einschätzung." />
  <section class="section">
    <div class="container grid three">
      <article class="card"><div class="card-body"><p class="eyebrow">Telefon</p><h3><a href={`tel:${company.phone.replace(/\s/g, "")}`}>{company.phone}</a></h3><p>Fax: {company.fax}</p></div></article>
      <article class="card"><div class="card-body"><p class="eyebrow">E-Mail</p><h3><a href={`mailto:${company.email}`}>{company.email}</a></h3><p>Für Projektanfragen, Bewerbungen und allgemeine Anliegen.</p></div></article>
      <article class="card"><div class="card-body"><p class="eyebrow">Adresse</p><h3>{company.street}</h3><p>{company.postalCity}</p></div></article>
    </div>
  </section>
  <section class="section soft compact">
    <div class="container">
      <p class="eyebrow">Anfahrt</p>
      <h2>Wolkersdorfer Straße 28, 35099 Burgwald-Bottendorf</h2>
      <div class="map-embed">
        <iframe
          src="https://www.google.com/maps?q=Wolkersdorfer+Stra%C3%9Fe+28,+35099+Burgwald-Bottendorf&output=embed"
          width="100%"
          height="400"
          style="border:0; border-radius:8px; display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Anfahrt zu Schreck Kunststofftechnik GmbH"
        ></iframe>
      </div>
    </div>
  </section>
  <section class="section soft">
    <div class="container split">
      <div>
        <p class="eyebrow">Anfrage vorbereiten</p>
        <h2>Hilfreich für eine schnelle Einschätzung</h2>
      </div>
      <div class="card">
        <div class="card-body">
          <ul>
            <li>Zeichnungen, Muster oder CAD-Daten</li>
            <li>Material, Stückzahlen und Zielbranche</li>
            <li>Anforderungen an Oberfläche, Zykluszeit und Qualität</li>
            <li>Geplanter Serienstart oder Zeitrahmen</li>
          </ul>
          <a class="button" href={`mailto:${company.email}?subject=Projektanfrage`}>E-Mail schreiben</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
