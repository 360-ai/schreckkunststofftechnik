---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  image?: string;
}

const { eyebrow, title, text, image = "/images/hero2.jpg" } = Astro.props;
---

<section class="page-hero" style={`background-image: linear-gradient(110deg, rgba(12,18,32,.95), rgba(12,18,32,.64)), url("${image}");`}>
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="lead">{text}</p>
  </div>
</section>
