---
import { company, navItems } from "@data/site";
---

<header class="site-header">
  <a class="brand" href="/" aria-label={`${company.name} Startseite`}>
    <img src="/images/logoschreck.png" alt={company.name} />
  </a>
  <nav aria-label="Hauptnavigation">
    {
      navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))
    }
  </nav>
  <div class="header-actions">
    <a class="header-phone" href={`tel:${company.phone.replace(/\s/g, "")}`} aria-label="Anrufen">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16v.92z"/>
      </svg>
    </a>
    <a class="contact" href={`mailto:${company.email}?subject=Projektanfrage`} aria-label="E-Mail Anfrage senden">Anfragen</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    z-index: 20;
    top: 0;
    left: 0;
    right: 0;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 28px;
    align-items: center;
    padding: 14px max(20px, calc((100vw - 1180px) / 2));
    border-bottom: 1px solid rgba(15, 31, 53, 0.1);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px);
    box-shadow: 0 10px 34px rgba(12, 18, 32, 0.06);
    color: var(--primary-deep);
  }

  .brand img {
    width: 172px;
    height: auto;
  }

  nav {
    display: flex;
    justify-content: center;
    gap: clamp(14px, 1.5vw, 24px);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  nav a {
    color: rgba(15, 31, 53, 0.78);
  }

  nav a:hover {
    color: var(--accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(8, 145, 178, 0.28);
    border-radius: 999px;
    color: var(--primary-deep);
    background: linear-gradient(135deg, rgba(8, 145, 178, 0.08), rgba(8, 145, 178, 0.14));
    transition: color 180ms, border-color 180ms;
  }

  .header-phone:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .contact {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(8, 145, 178, 0.28);
    border-radius: 999px;
    padding: 0 18px;
    background: linear-gradient(135deg, rgba(8, 145, 178, 0.12), rgba(8, 145, 178, 0.18));
    color: var(--primary-deep);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .site-header {
      position: fixed;
      grid-template-columns: 1fr auto;
      gap: 14px;
      padding: 12px 14px;
    }

    nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      overflow-x: auto;
      padding: 0 0 2px;
      scrollbar-width: none;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    .brand img {
      width: 150px;
    }
  }

  @media (max-width: 760px) {
    nav {
      display: none;
    }

    .brand img {
      width: 126px;
    }

    .header-phone {
      width: 36px;
      height: 36px;
    }

    .contact {
      min-height: 36px;
      padding: 0 12px;
      font-size: 0.86rem;
    }
  }
</style>
